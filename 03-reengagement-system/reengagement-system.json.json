      "parameters": {
        "jsCode": "const allItems = $input.all();\nconst total = allItems.length;\nconst immediate = allItems.filter(i => i.json.priority === 'Immediate').length;\nconst thisWeek = allItems.filter(i => i.json.priority === 'This Week').length;\nconst quarterly = allItems.filter(i => i.json.priority === 'Quarterly').length;\nconst avgScore = total > 0 \n  ? (allItems.reduce((sum, i) => sum + (Number(i.json.re_engagement_score) || 0), 0) / total).toFixed(1)\n  : 0;\n\nreturn [{\n  json: {\n    total_processed: total,\n    immediate_count: immediate,\n    this_week_count: thisWeek,\n    quarterly_count: quarterly,\n    avg_re_engagement_score: avgScore,\n    run_date: new Date().toLocaleDateString('en-US', { weekday: 'long', month: 'long', day: 'numeric' })\n  }\n}];"
