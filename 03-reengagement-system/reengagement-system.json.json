      "name": "Parse Scoring Output"
    },
    {
      "parameters": {
        "jsCode": "let raw = \"\";\n\ntry {\n  raw = $input.first().json.output[0].content[0].text || \"\";\n} catch(e) {\n  // If output structure is different or missing\n  raw = $input.first().json.text || $input.first().json.output || \"\";\n}\n\nraw = raw.replace(/```json\\s*/gi, '').replace(/```\\s*/gi, '').trim();\n\nconst start = raw.indexOf('{');\nconst end = raw.lastIndexOf('}');\n\nlet subject_line = \"\";\nlet email_body = \"\";\n\nif (start !== -1 && end !== -1) {\n  try {\n    const parsed = JSON.parse(raw.substring(start, end + 1));\n    subject_line = parsed.subject_line || parsed[\"Subject Line\"] || \"\";\n    email_body = parsed.email_body || parsed[\"Email Body\"] || \"\";\n  } catch(e) {\n    email_body = raw; // fallback вЂ” store raw text if JSON parse fails\n  }\n}\n\nreturn [{\n  json: {\n    ...$input.first().json,\n    subject_line: subject_line,\n    email_body: email_body\n  }\n}];"
      },
