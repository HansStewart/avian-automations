    {
      "parameters": {
        "promptType": "define",
        "text": "=You are a B2B content writer for AVIAN, an AI-powered thermal camera and \nfire prevention company targeting industrial manufacturers.\n\nBrand voice guidelines:\n{{ $('Brand Voice Agent').item.json.output }}\n\nWrite a blog post introduction using these details:\n- Topic: {{ $('Content Brief Input').item.json['Topic'] }}\n- Target Audience: {{ $('Content Brief Input').item.json['Target Audience'] }}\n- Key Message: {{ $('Content Brief Input').item.json['Key Message'] }}\n- Tone: {{ $('Content Brief Input').item.json['Tone'] }}\n\nRules:\n- 150-200 words\n- Open with a striking industry statistic or alarming fact\n- Establish the problem clearly by paragraph 2\n- End with a transition sentence that pulls the reader into the article\n- No generic openers like \"In today's world\" or \"As technology evolves\"\n\nReturn ONLY valid JSON:\n{\n  \"content_type\": \"Blog Introduction\",\n  \"headline\": \"SEO-optimized blog title\",\n  \"meta_description\": \"under 155 characters\",\n  \"introduction\": \"full blog intro here\",\n  \"word_count\": 000\n}",
        "options": {}
      },
