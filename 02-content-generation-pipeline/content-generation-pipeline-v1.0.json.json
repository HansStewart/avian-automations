    {
      "parameters": {
        "jsCode": "// ── Grab whichever content agent fired ──────────────────────────\nconst contentRaw = $('Carry Content Forward').first().json.content_agent_output || '';\n\n// ── Grab quality scores (already parsed by Parse Quality Scores) ──\nconst qualityJson = $input.first().json;\n\n// ── Grab original brief ──────────────────────────────────────────\nconst briefData = $('Content Brief Input').first().json;\n\n// ── Parse content JSON ───────────────────────────────────────────\nlet contentParsed = {};\ntry {\n  const match = contentRaw.match(/\\{[\\s\\S]*\\}/);\n  contentParsed = match ? JSON.parse(match[0]) : {};\n} catch(e) {\n  contentParsed = { \n    full_post: contentRaw, \n    body: contentRaw, \n    introduction: contentRaw \n  };\n}\n\n// ── Return final bundled object ──────────────────────────────────\nreturn [{\n  json: {\n    Content_Type:          briefData['Content Type']   || '',\n    Topic:                 briefData['Topic']           || '',\n    Target_Audience:       briefData['Target Audience'] || '',\n    Key_Message:           briefData['Key Message']     || '',\n    Tone:                  briefData['Tone']             || '',\n    Content_Output:        contentParsed.full_post || contentParsed.body || contentParsed.introduction || contentRaw,\n    Subject_Lines:         Array.isArray(contentParsed.subject_lines) ? contentParsed.subject_lines.join(' | ') : '',\n    Headline:              contentParsed.headline || '',\n    Clarity_Score:         qualityJson.clarity_score         || 0,\n    Brand_Voice_Score:     qualityJson.brand_voice_score     || 0,\n    Specificity_Score:     qualityJson.specificity_score     || 0,\n    CTA_Score:             qualityJson.cta_score             || 0,\n    Overall_Quality_Score: qualityJson.overall_score         || 0,\n    Passes_Quality_Gate:   qualityJson.passes_quality_gate   || false,\n    Reviewer_Notes:        qualityJson.reviewer_notes        || '',\n    Recommended_Changes:   qualityJson.recommended_changes   || '',\n    Generated_At:          new Date().toISOString()\n  }\n}];"
      },
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [
        2272,
        0
      ],
      "id": "9d4cf26f-4e02-4b1a-ac7d-a0f505bbd265",
      "name": "Bundle Final Output"
    },
    {
      "parameters": {
        "operation": "sendAndWait",
        "sendTo": "hans.stewart.contact@gmail.com",
        "subject": "=[AVIAN] Content Draft Ready — {{ $json.Content_Type }}: {{ $json.Topic }}",
        "message": "=A new content draft has been generated and scored by the AVIAN Content Pipeline.\n\n━━━━━━━━━━━━━━━━━━━━━━━━━━\nBRIEF DETAILS\n━━━━━━━━━━━━━━━━━━━━━━━━━━\nContent Type: {{ $json.Content_Type }}\nTopic: {{ $json.Topic }}\nTarget Audience: {{ $json.Target_Audience }}\nTone: {{ $json.Tone }}\n\n━━━━━━━━━━━━━━━━━━━━━━━━━━\nQUALITY SCORES\n━━━━━━━━━━━━━━━━━━━━━━━━━━\nOverall Score: {{ $json.Overall_Quality_Score }}/10\nClarity: {{ $json.Clarity_Score }}/10\nBrand Voice: {{ $json.Brand_Voice_Score }}/10\nSpecificity: {{ $json.Specificity_Score }}/10\nCTA Strength: {{ $json.CTA_Score }}/10\nQuality Gate: {{ $json.Passes_Quality_Gate }}\n\nReviewer Notes: {{ $json.Reviewer_Notes }}\nRecommended Changes: {{ $json.Recommended_Changes }}\n\n━━━━━━━━━━━━━━━━━━━━━━━━━━\nCONTENT DRAFT\n━━━━━━━━━━━━━━━━━━━━━━━━━━\n{{ $json.Content_Output }}\n\n{{ $json.Subject_Lines }}\n{{ $json.Headline }}",
        "approvalOptions": {
          "values": {
            "approvalType": "double"
          }
        },
        "options": {}
      },
