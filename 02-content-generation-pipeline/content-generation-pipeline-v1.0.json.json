    {
      "parameters": {
        "content": "[AVIAN] Content Generation Pipeline v1.0\nClient: AVIAN Technologies\nOwner: Hans Stewart\nLast Updated: May 2026\nStatus: Production Active\n\nArchitecture: Form trigger → Live brand voice extraction (Jina/avian-iot.com) \n→ Channel routing (LinkedIn / Email / Blog) → Specialist content agents \n→ Quality scoring gate → Human approval via Gmail → Content library output\n\nNote: Brand voice is pulled live from AVIAN's website on every run — \nno static brand guide needed. Quality gate requires all 4 scores ≥ 7 \nbefore approval email fires.",
        "height": 240,
        "width": 592
      },
      "type": "n8n-nodes-base.stickyNote",
      "typeVersion": 1,
      "position": [
        816,
        -656
      ],
      "id": "011d7708-9bc0-4704-8096-4bc6b4c01e95",
      "name": "Sticky Note"
    },
    {
      "parameters": {
        "content": "Human-in-the-Loop Approval Gate\nWorkflow pauses here until human approves or rejects.\nApproval email includes full draft + all 4 quality scores.\nOnly fires if Quality Critic scores all dimensions ≥ 7.\nNothing writes to Content Library without explicit approval.\nThis is intentional — governed AI, not blind automation.",
        "height": 224,
        "width": 288
      },
      "type": "n8n-nodes-base.stickyNote",
      "typeVersion": 1,
      "position": [
        2448,
        -256
      ],
      "id": "f7e40d0a-5600-4e04-ad2f-609bf5ebcf6a",
      "name": "Sticky Note1"
    },
    {
      "parameters": {
        "jsCode": "const raw = $input.first().json.output || \"\";\n\nlet parsed = {};\ntry {\n  const match = raw.match(/\\{[\\s\\S]*\\}/);\n  parsed = JSON.parse(match[0]);\n} catch(e) {\n  parsed = {\n    clarity_score: 0,\n    brand_voice_score: 0,\n    specificity_score: 0,\n    cta_score: 0,\n    overall_score: 0,\n    passes_quality_gate: false,\n    reviewer_notes: \"Parse error — quality check failed\",\n    recommended_changes: \"Regenerate content\"\n  };\n}\n\nreturn [{\n  json: {\n    ...$input.first().json,\n    clarity_score: parsed.clarity_score || 0,\n    brand_voice_score: parsed.brand_voice_score || 0,\n    specificity_score: parsed.specificity_score || 0,\n    cta_score: parsed.cta_score || 0,\n    overall_score: parsed.overall_score || 0,\n    passes_quality_gate: parsed.passes_quality_gate === true,\n    reviewer_notes: parsed.reviewer_notes || \"\",\n    recommended_changes: parsed.recommended_changes || \"\"\n  }\n}];"
      },
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [
        1744,
        0
      ],
      "id": "f8345519-f0c8-4cfb-a51e-77a9c3eab48f",
      "name": "Parse Quality Scores"
    },
    {
      "parameters": {
        "jsCode": "return [{\n  json: {\n    ...$input.first().json,\n    quality_failure: true,\n    failure_summary: `Quality gate failed. Scores — Clarity: ${$input.first().json.clarity_score}, Brand Voice: ${$input.first().json.brand_voice_score}, Specificity: ${$input.first().json.specificity_score}, CTA: ${$input.first().json.cta_score}. Notes: ${$input.first().json.reviewer_notes}`\n  }\n}];"
      },
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [
        2096,
        80
      ],
      "id": "6c61efa4-f438-42f7-a3e3-cee969f7f6fb",
      "name": "Flag Quality Failure"
    },
    {
      "parameters": {
        "jsCode": "// This node runs right after whichever content agent fired\n// It preserves the content output in a field that travels with the data\nreturn [{\n  json: {\n    ...$input.first().json,\n    content_agent_output: $input.first().json.output || \"\"\n  }\n}];"
      },
