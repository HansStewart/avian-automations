        2608,
        528
      ],
      "id": "dcf147c2-d4fa-4d3a-9d6d-15c25d697d0f",
      "name": "Max Retries Reached?"
    },
    {
      "parameters": {
        "jsCode": "const currentAttempt = $input.first().json.retry_count || 0;\nlet failureReason = \"\";\n\n// Try to extract failure reason from Quality Critic output\ntry {\n  const output = $input.first().json.output;\n  const parsed = JSON.parse(output.match(/\\{[\\s\\S]*\\}/)?.[0] || \"{}\");\n  failureReason = parsed.failure_reason || \"\";\n} catch(e) {\n  failureReason = \"Could not parse quality output\";\n}\n\nreturn [{\n  json: {\n    ...$input.first().json,\n    retry_count: currentAttempt + 1,\n    failure_reason: failureReason\n  }\n}];"
      },
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [
        2608,
        336
      ],
      "id": "aec7a332-f90a-486c-a89c-6a8b328a4db0",
      "name": "Retry Counter"
    },
    {
      "parameters": {
        "jsCode": "const output = $input.first().json.output || \"\";\n\nconst emailMatch = output.match(/EMAIL OPENER:\\s*([\\s\\S]+?)(?=\\nLINKEDIN MESSAGE:|$)/);\nconst linkedinMatch = output.match(/LINKEDIN MESSAGE:\\s*([\\s\\S]+?)(?=\\nCALL POINT 1:|$)/);\nconst call1Match = output.match(/CALL POINT 1:\\s*([\\s\\S]+?)(?=\\nCALL POINT 2:|$)/);\nconst call2Match = output.match(/CALL POINT 2:\\s*([\\s\\S]+?)(?=\\nCALL POINT 3:|$)/);\nconst call3Match = output.match(/CALL POINT 3:\\s*([\\s\\S]+?)(?=\\n|$)/);\n\nreturn [{\n  json: {\n    ...$input.first().json,\n    email_opener: emailMatch ? emailMatch[1].trim() : \"\",\n    linkedin_message: linkedinMatch ? linkedinMatch[1].trim() : \"\",\n    call_point_1: call1Match ? call1Match[1].trim() : \"\",\n    call_point_2: call2Match ? call2Match[1].trim() : \"\",\n    call_point_3: call3Match ? call3Match[1].trim() : \"\"\n  }\n}];"
      },
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [
        2064,
        128
      ],
      "id": "e8ce4317-3376-43a6-93e3-4adca75fd560",
      "name": "Parse Personalization Output"
    },
    {
      "parameters": {
        "jsCode": "const researchText = $('Research Analyst').item.json.text || \"\";\n\n// Extract each field\nconst employeesMatch = researchText.match(/EMPLOYEES:\\s*(.+?)(?=\\n|$)/);\nconst companySizeMatch = researchText.match(/COMPANY SIZE:\\s*(.+?)(?=\\n|$)/);\nconst painSignalsMatch = researchText.match(/PAIN SIGNALS:\\s*(.+?)(?=\\n|$)/);\nconst painRatingMatch = researchText.match(/PAIN RATING:\\s*(.+?)(?=\\n|$)/);\n\nreturn [{\n  json: {\n    ...$input.first().json,\n    employees: employeesMatch ? employeesMatch[1].trim() : \"Unknown\",\n    company_size: companySizeMatch ? companySizeMatch[1].trim() : \"Unknown\",\n    pain_signals_clean: painSignalsMatch ? painSignalsMatch[1].trim() : \"No signals detected\",\n    pain_rating: painRatingMatch ? painRatingMatch[1].trim() : \"Unknown\"\n  }\n}];"
      },
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [
        1488,
        128
      ],
      "id": "4a750228-e86b-4aac-b89a-21ea978dc997",
      "name": "Parse Research Output"
    }
