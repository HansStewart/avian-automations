    {
      "parameters": {
        "jsCode": "const output = $input.first().json.output;\n\n// Extract total score\nconst scoreMatch = output.match(/Total Score:\\s*(\\d+)\\/100/);\nconst tierMatch = output.match(/ICP Tier:\\s*(Hot|Warm|Cold)/);\nconst summaryMatch = output.match(/Summary:\\s*(.+?)(?:\\n|$)/);\n\nreturn [{\n  json: {\n    ...$input.first().json,\n    icp_score_clean: scoreMatch ? scoreMatch[1] : \"N/A\",\n    icp_tier_clean: tierMatch ? tierMatch[1].trim() : \"Unknown\",\n    icp_summary: summaryMatch ? summaryMatch[1].trim() : \"\",\n    raw_icp_output: output\n  }\n}];\n"
      },
